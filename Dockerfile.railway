# syntax=docker/dockerfile:1
#
# Railway-specific Dockerfile.
# Differences from the default Dockerfile:
#   - single-platform build (no cross-compile / BUILDPLATFORM)
#   - honours $PORT at runtime (Railway injects it)
#   - runs as root (Railway manages isolation)

# ── Stage 1: Build ────────────────────────────────────────────
FROM alpine:3.23 AS builder

RUN apk add --no-cache zig musl-dev

WORKDIR /app
COPY build.zig build.zig.zon ./
COPY src/ src/
COPY vendor/sqlite3/ vendor/sqlite3/

RUN zig build -Doptimize=ReleaseSmall

# ── Stage 2: Config Prep ─────────────────────────────────────
FROM busybox:1.37 AS config

RUN mkdir -p /nullclaw-data/.nullclaw /nullclaw-data/workspace

RUN cat > /nullclaw-data/.nullclaw/config.json << 'EOF'
{
  "default_temperature": 0.7,
  "max_tokens": 2048,
  "models": {
    "providers": {
      "openrouter": {
        "api_key": ""
      },
      "openai": {
        "api_key": ""
      },
      "gemini": {
        "api_key": ""
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4"
      }
    }
  },
  "channels": {
    "slack": {
      "accounts": {
        "main": {
          "bot_token": "",
          "app_token": "",
          "allow_from": ["*"]
        }
      }
    },
    "web": {
      "default": {
        "transport": "local",
        "port": 32123,
        "listen": "127.0.0.1",
        "path": "/ws",
        "message_auth_mode": "token",
        "allowed_origins": ["*"],
        "max_connections": 64
      }
    }
  },
  "gateway": {
    "port": 3001,
    "host": "::",
    "require_pairing": false
  }
}
EOF

# ── Stage 3: Runtime ──────────────────────────────────────────
FROM alpine:3.23

LABEL org.opencontainers.image.source=https://github.com/nullclaw/nullclaw

RUN apk add --no-cache ca-certificates curl tzdata jq nginx

COPY --from=builder /app/zig-out/bin/nullclaw /usr/local/bin/nullclaw
COPY --from=config /nullclaw-data /nullclaw-data

# nginx config: reverse proxy port 3000 -> gateway (3001) + web channel WS (32123)
RUN mkdir -p /run/nginx && cat > /etc/nginx/http.d/default.conf << 'NGINX'
server {
    listen 3000;
    listen [::]:3000;

    # WebSocket: /ws -> nullclaw web channel on 32123
    # Clear bulky browser/Railway headers to stay under nullclaw's
    # 1024-byte WebSocket handshake buffer while keeping essential
    # WS headers (Upgrade, Connection, Sec-WebSocket-*).
    location /ws {
        proxy_pass http://127.0.0.1:32123;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host "localhost";
        # Clear large browser headers
        proxy_set_header Accept "";
        proxy_set_header Accept-Encoding "";
        proxy_set_header Accept-Language "";
        proxy_set_header User-Agent "";
        proxy_set_header Cookie "";
        proxy_set_header Origin "";
        proxy_set_header Cache-Control "";
        proxy_set_header Pragma "";
        proxy_set_header Sec-Fetch-Dest "";
        proxy_set_header Sec-Fetch-Mode "";
        proxy_set_header Sec-Fetch-Site "";
        proxy_set_header Sec-Fetch-User "";
        proxy_set_header Sec-GPC "";
        proxy_set_header DNT "";
        proxy_set_header Sec-WebSocket-Extensions "";
        # Clear Railway/proxy-added headers
        proxy_set_header X-Forwarded-For "";
        proxy_set_header X-Forwarded-Proto "";
        proxy_set_header X-Forwarded-Host "";
        proxy_set_header X-Real-IP "";
        proxy_set_header X-Request-ID "";
        proxy_set_header X-Envoy-External-Address "";
        proxy_set_header Via "";
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # Everything else -> nullclaw gateway on 3001
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 30s;
    }
}
NGINX

# Startup script: inject env-var secrets into config.json, start nginx, then exec nullclaw.
RUN cat > /usr/local/bin/start.sh << 'SCRIPT'
#!/bin/sh
set -e
CFG="/nullclaw-data/.nullclaw/config.json"

# Inject OpenRouter API key
if [ -n "$OPENROUTER_API_KEY" ]; then
  jq --arg k "$OPENROUTER_API_KEY" '.models.providers.openrouter.api_key = $k' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject Gemini API key (fallback)
if [ -n "$GEMINI_API_KEY" ]; then
  jq --arg k "$GEMINI_API_KEY" '.models.providers.gemini.api_key = $k' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject Slack bot token
if [ -n "$SLACK_BOT_TOKEN" ]; then
  jq --arg t "$SLACK_BOT_TOKEN" '.channels.slack.accounts.main.bot_token = $t' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject Slack app-level token
if [ -n "$SLACK_APP_TOKEN" ]; then
  jq --arg t "$SLACK_APP_TOKEN" '.channels.slack.accounts.main.app_token = $t' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject Slack signing secret
if [ -n "$SLACK_SIGNING_SECRET" ]; then
  jq --arg s "$SLACK_SIGNING_SECRET" '.channels.slack.accounts.main.signing_secret = $s' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject OpenAI API key
if [ -n "$OPENAI_API_KEY" ]; then
  jq --arg k "$OPENAI_API_KEY" '.models.providers.openai.api_key = $k' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Inject Web channel auth token
if [ -n "$NULLCLAW_WEB_TOKEN" ]; then
  jq --arg t "$NULLCLAW_WEB_TOKEN" '.channels.web.default.auth_token = $t' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Override default model if NULLCLAW_MODEL env var is set
if [ -n "$NULLCLAW_MODEL" ]; then
  jq --arg m "$NULLCLAW_MODEL" '.agents.defaults.model.primary = $m' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
fi

# Debug: test curl connectivity before starting nullclaw
echo "=== STARTUP DIAGNOSTICS ==="
echo "curl version: $(curl --version | head -1)"
echo "which curl: $(which curl)"
echo "DNS test (openrouter.ai):"
nslookup openrouter.ai 2>&1 | head -5 || echo "nslookup not available"
echo "curl test (OpenRouter auth/key):"
if [ -n "$OPENROUTER_API_KEY" ]; then
  MASKED_KEY="$(echo "$OPENROUTER_API_KEY" | cut -c1-8)...$(echo "$OPENROUTER_API_KEY" | rev | cut -c1-4 | rev)"
  echo "  API key: $MASKED_KEY"
  curl -sv --max-time 10 -H "Authorization: Bearer $OPENROUTER_API_KEY" https://openrouter.ai/api/v1/auth/key 2>&1 | tail -20
else
  echo "  OPENROUTER_API_KEY not set!"
fi
echo "curl test (Gemini):"
if [ -n "$GEMINI_API_KEY" ]; then
  curl -s --max-time 10 "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY" 2>&1 | head -5
else
  echo "  GEMINI_API_KEY not set!"
fi
echo "Proxy env vars:"
echo "  HTTPS_PROXY=${HTTPS_PROXY:-unset}"
echo "  HTTP_PROXY=${HTTP_PROXY:-unset}"
echo "  ALL_PROXY=${ALL_PROXY:-unset}"
echo "  https_proxy=${https_proxy:-unset}"
echo "  http_proxy=${http_proxy:-unset}"
echo "Config (masked):"
jq '.models.providers | to_entries | map({key: .key, has_key: (.value.api_key | length > 0)})' "$CFG" 2>/dev/null
echo "Model: $(jq -r '.agents.defaults.model.primary' "$CFG" 2>/dev/null)"
echo "=== END DIAGNOSTICS ==="

# Start nginx in background (reverse proxy on port 3000)
nginx

# Start nullclaw gateway on port 3001 (nginx proxies to it)
exec nullclaw "$@"
SCRIPT
RUN chmod +x /usr/local/bin/start.sh

ENV NULLCLAW_WORKSPACE=/nullclaw-data/workspace
ENV HOME=/nullclaw-data
ENV PORT=3000

WORKDIR /nullclaw-data
EXPOSE ${PORT}
ENTRYPOINT ["/usr/local/bin/start.sh"]
CMD ["gateway", "--port", "3001", "--host", "::"]
